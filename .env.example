# ── Docker / Database ─────────────────────────────────────────────────────────
# Password for the PostgreSQL container.  Change before any internet exposure.
POSTGRES_PASSWORD=changeme

# ── Backend API ───────────────────────────────────────────────────────────────
# Overridden automatically by docker-compose to point at the db container.
# Only set this manually when running the backend outside Docker.
# DATABASE_URL=postgresql+asyncpg://peck_deck:changeme@localhost:5432/peck_deck

# JWT signing secret — must be long and random in production.
JWT_SECRET=change_this_to_a_long_random_string
JWT_EXPIRE_HOURS=24

# ── Email notifications (M4) ──────────────────────────────────────────────────
SENDGRID_API_KEY=
NOTIFICATION_FROM_EMAIL=notifications@peckdeck.local

# ── SMS notifications (M4) ────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# ── Notification throttle (M4) ────────────────────────────────────────────────
# Minimum seconds between notifications per device (default 60).
NOTIFICATION_MIN_INTERVAL_SECONDS=60

# ── Cloud classification (M6) ─────────────────────────────────────────────────
# CLAUDE_API_KEY=

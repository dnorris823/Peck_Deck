# Backend API (gaming PC)
BACKEND_URL=http://192.168.1.100:8000
DEVICE_TOKEN=your_device_token_here

# GPU inference server (Tier 2)
INFERENCE_SERVER_URL=http://192.168.1.100:8001

# Classification
# Preference: auto | local | gpu | cloud
TIER_PREFERENCE=auto
CONFIDENCE_THRESHOLD=0.5
TIER2_REQUEST_TIMEOUT=30
BACKEND_CONNECT_TIMEOUT=10
BACKEND_UPLOAD_TIMEOUT=60

# Trigger peripheral
# Type: pir | ir_beam
TRIGGER_TYPE=pir
TRIGGER_GPIO_PIN=17
DEBOUNCE_SECONDS=30

# Camera
IMAGE_WIDTH=1920
IMAGE_HEIGHT=1080
JPEG_QUALITY=90

# Local storage
CACHE_DIR=/var/lib/peck_deck/cache
MAX_CACHE_IMAGES=25

# ML models (defaults resolve relative to project root)
# MODEL_PATH=/home/pi/peck_deck/machine_learning/INatVision_Small_2_fact256_8bit.tflite
# TAXONOMY_PATH=/home/pi/peck_deck/machine_learning/taxonomy.csv

# Background sync interval (seconds)
SYNC_INTERVAL_SECONDS=60
